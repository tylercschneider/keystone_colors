<%= ui_page_header(title: "Color Settings") %>

<% if flash[:notice] %>
  <div class="mb-4 px-4 py-3 rounded-lg bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-200 text-sm">
    <%= flash[:notice] %>
  </div>
<% end %>

<%
  current_accent_hex = if @preference.accent&.start_with?("#")
    @preference.accent
  else
    KeystoneColors::Palettes.accent(@preference.accent || "blue")[500]
  end

  current_surface_hex = if @preference.surface&.start_with?("#")
    @preference.surface
  else
    KeystoneColors::Palettes.surface(@preference.surface || "zinc")[500]
  end
%>

<%= ui_panel(padding: :lg) do %>
  <%= form_with(
    url: engine_root_path,
    method: :patch,
    scope: :theme_preference,
    data: { turbo: false, controller: "keystone-colors--theme-settings" }
  ) do |form| %>
    <div class="space-y-8">
      <div>
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Theme</h3>
        <div class="flex flex-wrap gap-2">
          <% KeystoneColors::Templates.names.each do |name| %>
            <% template = KeystoneColors::Templates[name] %>
            <% accent_hex = KeystoneColors::Palettes.accent(template[:accent])[500] %>
            <% surface_hex = KeystoneColors::Palettes.surface(template[:surface])[500] %>
            <label class="relative cursor-pointer">
              <input type="radio" name="theme_preference[template_name]" value="<%= name %>"
                <%= "checked" if @preference.template_name == name.to_s %>
                data-action="keystone-colors--theme-settings#selectTemplate"
                data-accent="<%= template[:accent] %>"
                data-surface="<%= template[:surface] %>"
                data-accent-hex="<%= accent_hex %>"
                data-surface-hex="<%= surface_hex %>"
                class="peer absolute opacity-0">
              <span class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-200 dark:border-zinc-700 peer-checked:border-blue-500 peer-checked:ring-2 peer-checked:ring-blue-500/20 transition">
                <span class="w-4 h-4 rounded-full" style="background-color: <%= accent_hex %>"></span>
                <span class="w-4 h-4 rounded" style="background-color: <%= surface_hex %>"></span>
                <span class="text-sm text-gray-700 dark:text-gray-300"><%= template[:label] %></span>
              </span>
            </label>
          <% end %>
          <label class="relative cursor-pointer">
            <input type="radio" name="theme_preference[template_name]" value=""
              <%= "checked" if @preference.accent&.start_with?("#") || @preference.template_name.blank? && @preference.persisted? %>
              data-keystone-colors--theme-settings-target="customRadio"
              class="peer absolute opacity-0">
            <span class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-200 dark:border-zinc-700 peer-checked:border-blue-500 peer-checked:ring-2 peer-checked:ring-blue-500/20 transition">
              <span class="text-sm text-gray-700 dark:text-gray-300">Custom</span>
            </span>
          </label>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Accent Color</h3>
        <div class="flex items-center gap-4">
          <input type="color" name="theme_preference[accent]" value="<%= current_accent_hex %>"
            data-action="keystone-colors--theme-settings#customColorChanged"
            data-keystone-colors--theme-settings-target="accentPicker"
            class="w-12 h-12 rounded-lg cursor-pointer border-0 p-0">
          <span class="text-sm text-gray-500 dark:text-gray-400" data-keystone-colors--theme-settings-target="accentLabel"><%= current_accent_hex %></span>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Surface</h3>
        <div class="flex items-center gap-4">
          <input type="color" name="theme_preference[surface]" value="<%= current_surface_hex %>"
            data-action="keystone-colors--theme-settings#customColorChanged"
            data-keystone-colors--theme-settings-target="surfacePicker"
            class="w-12 h-12 rounded-lg cursor-pointer border-0 p-0">
          <span class="text-sm text-gray-500 dark:text-gray-400" data-keystone-colors--theme-settings-target="surfaceLabel"><%= current_surface_hex %></span>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= ui_button(label: "Save", type: :submit) %>
      </div>
    </div>
  <% end %>

  <% if @preference.persisted? %>
    <div class="mt-6 pt-6 border-t border-gray-200 dark:border-zinc-700">
      <%= button_to "Reset to Default", engine_root_path, method: :delete, data: { turbo: false } %>
    </div>
  <% end %>
<% end %>
